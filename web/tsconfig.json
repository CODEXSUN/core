{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@codexsun/ui": ["../../ui/src/index.ts"],
      "@codexsun/ui/styles.css": ["../../ui/src/styles.css"],
      "@codexsun/ui/components/*": ["../../ui/src/components/*"],
      "@codexsun/ui/layouts/*": ["../../ui/src/layouts/*"],
      "@codexsun/ui/blocks/*": ["../../ui/src/blocks/*"],
      "@codexsun/ui/workspace": ["../../ui/src/workspace/index.ts"],
      "@codexsun/ui/workspace/*": ["../../ui/src/workspace/*"],
      "@codexsun/ui/presets/*": ["../../ui/src/workspace/presets/*"],
      "@codexsun/ui/lib/*": ["../../ui/src/lib/*"]
    },
    "noEmit": true,
    "types": ["vite/client", "node"]
  },
  "include": ["src"]
}
